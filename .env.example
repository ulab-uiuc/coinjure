# Polymarket CLOB API Credentials
POLYMARKET_API_KEY=your-polymarket-api-key
POLYMARKET_API_SECRET=your-polymarket-api-secret
POLYMARKET_API_PASSPHRASE=your-polymarket-api-passphrase

# Polymarket Wallet Private Key (required for live trading / signing orders)
# POLYMARKET_PRIVATE_KEY=your-wallet-private-key

# Kalshi API Credentials (required for Kalshi trading)
# KALSHI_API_KEY_ID=your-kalshi-api-key-id
# KALSHI_PRIVATE_KEY_PATH=/path/to/your/kalshi-private-key.pem

# DeepSeek API Key (for LLM strategies)
DEEPSEEK_API_KEY=your-deepseek-api-key
